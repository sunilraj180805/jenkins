pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                echo "Code pulled from GitHub successfully!"
            }
        }

        stage('Build') {
            steps {
                echo "Building the project..."
            }
        }

        stage('Test') {
            steps {
                echo "Running tests..."
            }
        }

        stage('Success') {
            steps {
                echo "Pipeline completed successfully 🚀"
            }
        }
    }
}
